# Copy this file to ".env" and paste your real values in.
# The .env file is git-ignored so your secret key stays local.

# Secret key from Retell dashboard -> API Keys.  Looks like: key_xxxxxxxxxxxx
# NEVER share this or paste it into chat / the webpage.
RETELL_API_KEY=

# Agent ID from Retell dashboard -> Agents -> "WMIC - Voice Agent Pro".
# Safe to share. Looks like: agent_xxxxxxxxxxxx
AGENT_ID=

# Optional: change the local port (default 3000)
# PORT=3000
